{
	"name": "pakamew",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"build": "mprocs --config scripts/mprocs/pnpm-build.yaml",
		"build:server": "pnpm --filter @pakamew/server run build",
		"build:web": "pnpm --filter @pakamew/web run build",
		"dev": "mprocs --config scripts/mprocs/pnpm-dev.yaml",
		"dev:server": "pnpm --filter @pakamew/server run dev",
		"dev:web": "pnpm --filter @pakamew/web run dev",
		"start:livestream-node": "pnpm --filter @pakamew/livestream-node run start",
		"preview": "mprocs --config scripts/mprocs/pnpm-preview.yaml",
		"preview:server": "pnpm --filter @pakamew/server run preview",
		"preview:web": "pnpm --filter @pakamew/web run preview",
		"ci": "mprocs --config scripts/mprocs/pnpm-ci.yaml",
		"eslint": "eslint .",
		"eslint:fix": "eslint . --fix",
		"prettier": "prettier --check .",
		"prettier:write": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"tsc:check": "tsc -b --noEmit",
		"tsgo:check": "tsgo -b --noEmit",
		"commitlint": "commitlint --edit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*": [
			"pnpm prettier:write"
		],
		"*.{ts,tsx,cts,mts}": [
			"pnpm eslint"
		]
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.4",
		"@orpc/client": "^1.13.14",
		"better-auth": "^1.6.4",
		"dotenv": "^17.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@clack/prompts": "^1.2.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@types/node": "^24.10.1",
		"@typescript/native-preview": "7.0.0-dev.20260222.1",
		"dependency-cruiser": "^17.3.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-react-dom": "^4.2.3",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-react-x": "^4.2.3",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mprocs": "^0.9.2",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"ts-essentials": "^10.1.1",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"eslint-plugin-react-hooks>eslint": "^10.0.0"
			}
		},
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"@serialport/bindings-cpp",
			"better-sqlite3",
			"core-js",
			"esbuild",
			"msw",
			"prisma",
			"protobufjs"
		]
	}
}
