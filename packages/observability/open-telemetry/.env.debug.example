# shellcheck shell=sh
# shellcheck disable=SC2034
# ^^ Added the rules above to suppress unrelated shell warnings

# OpenTelemetry collector / LGTM preset: debug
ENABLE_LOGS_OTELCOL=true
TAIL_SAMPLING_DECISION_WAIT=10s
TAIL_SAMPLING_NUM_TRACES=50000
TAIL_SAMPLING_EXPECTED_NEW_TRACES_PER_SEC=1000
TAIL_SAMPLING_LATENCY_THRESHOLD_MS=1000
TAIL_SAMPLING_NON_ERROR_PERCENT=100
