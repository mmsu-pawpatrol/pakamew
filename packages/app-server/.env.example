# shellcheck shell=sh
# shellcheck disable=SC2034
# ^^ Added the rules above to suppress unrelated shell warnings

DATABASE_URL="postgresql://pakamew:pakamew@localhost:5432/pakamew?schema=public"

BETTER_AUTH_SECRET=secret
BETTER_AUTH_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

HOST=localhost
PORT=3001

MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DEVICE_ID=feeder-1
MQTT_COMMAND_TOPIC=pakamew/demo/feeder-1/commands
MQTT_STATUS_TOPIC=pakamew/demo/feeder-1/status
MQTT_EVENTS_TOPIC=pakamew/demo/feeder-1/events
MQTT_ACK_TIMEOUT_MS=2500

XENDIT_SECRET_KEY=xnd_development_example
XENDIT_BASE_URL=https://api.xendit.co
XENDIT_WEBHOOK_CALLBACK_TOKEN=example-callback-token
XENDIT_SUCCESS_RETURN_URL=https://example.ngrok-free.app/donate/success
XENDIT_CANCEL_RETURN_URL=https://example.ngrok-free.app/donate
XENDIT_ALLOWED_PAYMENT_CHANNELS=GCASH,PAYMAYA,GRABPAY,SHOPEEPAY

# OpenTelemetry is optional.
# - OTEL_ENABLED=false: OTEL_* vars are ignored.
# - OTEL_ENABLED=true: OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_SERVICE_NAME, and OTEL_SERVICE_VERSION are required.
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=pakamew-server
# OTEL_SERVICE_VERSION=0.0.0
# OTEL_DEPLOYMENT_ENVIRONMENT=development

# Preset: debug | dev | test | staging | prod
# OBS_PRESET=dev
OBS_ERROR_TRACE_WINDOW_MS=120000
# OBS_LOG_LEVEL=info
# OBS_METRICS_DETAIL_LEVEL=medium
# OBS_METRICS_EXPORT_INTERVAL_MS=10000

# OBS_ENABLE_DEV_TRACING=false
# OBS_ENABLE_ORPC_LOG_REQUEST_RESPONSE=true
# OBS_ENABLE_ORPC_LOG_REQUEST_ABORT=true
# OBS_ENABLE_PRISMA_LOG_QUERIES=true
