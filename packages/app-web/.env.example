# shellcheck shell=sh
# shellcheck disable=SC2034
# ^^ Added the rules above to suppress unrelated shell warnings

# Backend base URL. The app appends `/api` and uses this same origin
# for Better Auth endpoints such as `/api/auth/*`.
VITE_API_URL=http://127.0.0.1:3001

# Public OvenMediaEngine playback URL consumed by the HLS player path.
VITE_LIVESTREAM_PUBLIC_HLS_URL=http://127.0.0.1:3333/app/esp32/master.m3u8

# Livestream gateway websocket URL used by the raw-frame fallback/debug viewer path.
VITE_LIVESTREAM_GATEWAY_WS_URL=ws://127.0.0.1:3000/viewer
HOST=127.0.0.1
PORT=5173
