# shellcheck shell=sh
# shellcheck disable=SC2034
# ^^ Added the rules above to suppress unrelated shell warnings

# Backend base URL. The app appends `/api` and uses this same origin
# for Better Auth endpoints such as `/api/auth/*`.
# Production example:
# VITE_API_URL=https://api.pakamew.site
VITE_API_URL=http://localhost:3001

# Public OvenMediaEngine playback URL consumed by the HLS player path.
# Production example:
# VITE_LIVESTREAM_PUBLIC_HLS_URL=https://ls.pakamew.site/app/esp32/master.m3u8
VITE_LIVESTREAM_PUBLIC_HLS_URL=http://localhost:3333/app/esp32/master.m3u8

# Livestream gateway websocket URL used by the raw-frame fallback/debug viewer path.
# Production example:
# VITE_LIVESTREAM_GATEWAY_WS_URL=wss://lsg.pakamew.site/viewer
VITE_LIVESTREAM_GATEWAY_WS_URL=ws://localhost:3000/viewer
HOST=localhost
PORT=5173
