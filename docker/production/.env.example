# -----------------------------------------------------------------------------
# Locally built image tags
# -----------------------------------------------------------------------------

# Base production compose builds these images locally and tags them with these names.
APP_SERVER_IMAGE=pakamew-app-server:prod-local
LIVESTREAM_NODE_IMAGE=pakamew-livestream-node:prod-local

# Registry image tags used by docker-compose.registry.yml in real deployments.
APP_SERVER_REGISTRY_IMAGE=ghcr.io/mmsu-pawpatrol/pakamew-app-server:latest
LIVESTREAM_NODE_REGISTRY_IMAGE=ghcr.io/mmsu-pawpatrol/pakamew-livestream-node:latest

# Infra image versions for the production stack.
TRAEFIK_IMAGE=traefik:v3.6.13
GRAFANA_ALLOY_IMAGE=grafana/alloy:latest

# -----------------------------------------------------------------------------
# Grafana upstream
# -----------------------------------------------------------------------------

# Grafana Cloud OTLP gateway used by Alloy to forward logs, metrics, and traces.
# Replace this with your real regional Grafana Cloud OTLP endpoint ending in /otlp.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp

# Grafana Cloud OTLP basic auth credentials.
# Grafana Cloud typically uses the stack/user ID as username and an API key as password.
GRAFANA_CLOUD_OTLP_USERNAME=123456
GRAFANA_CLOUD_OTLP_API_KEY=glc_example_api_key

# -----------------------------------------------------------------------------
# Grafana Alloy tail sampling
# -----------------------------------------------------------------------------

# Tail-sampling settings for the production Alloy trace pipeline.
TAIL_SAMPLING_DECISION_WAIT=10s
TAIL_SAMPLING_NUM_TRACES=50000
TAIL_SAMPLING_EXPECTED_NEW_TRACES_PER_SEC=1000
TAIL_SAMPLING_LATENCY_THRESHOLD_MS=1000
TAIL_SAMPLING_NON_ERROR_PERCENT=2

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------

# Host bind settings for the Postgres port.
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_HOST_PORT=5432

# Database settings shared by the Postgres container and the app-server override URL.
POSTGRES_DB=pakamew
POSTGRES_USER=pakamew
POSTGRES_PASSWORD=pakamew

# Docker DNS target used when rewriting DATABASE_URL inside the production stack.
APP_SERVER_DATABASE_HOST=postgres
APP_SERVER_DATABASE_PORT=5432
APP_SERVER_DATABASE_SCHEMA=public

# ----------------------------------------------------------------------------- 
# App server
# ----------------------------------------------------------------------------- 

# Internal bind settings for the app-server container.
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=3001

# Deployment environment label sent to OTEL.
APP_SERVER_OTEL_DEPLOYMENT_ENVIRONMENT=prod

# Docker DNS target used when rewriting the OTLP endpoint inside the production stack.
APP_SERVER_OTEL_HOST=alloy
APP_SERVER_OTEL_PORT=4318
APP_SERVER_OTEL_GRPC_PORT=4317

# -----------------------------------------------------------------------------
# Livestream node
# -----------------------------------------------------------------------------

# Internal bind settings and startup mode for the livestream gateway container.
LIVESTREAM_NODE_PORT=3000
LIVESTREAM_NODE_SCRIPT=start:wifi:ome

# Docker DNS target used when rewriting the OME RTMP URL inside the production stack.
OME_RTMP_HOST=ovenmediaengine
OME_RTMP_PORT=1935
OME_RTMP_APPLICATION=app
OME_RTMP_STREAM_KEY=esp32

# -----------------------------------------------------------------------------
# Traefik published ports
# -----------------------------------------------------------------------------

# Traefik publishes these ports and forwards backend/gateway traffic to internal containers.
TRAEFIK_HTTP_BIND_IP=0.0.0.0
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_BIND_IP=0.0.0.0
TRAEFIK_HTTPS_PORT=443

# Public backend endpoint exposed through Traefik.
# This is the host-facing published port. Traefik still listens on its internal
# appserver entrypoint port inside the container.
TRAEFIK_APP_SERVER_BIND_IP=0.0.0.0
TRAEFIK_APP_SERVER_PORT=3001

# Public livestream gateway endpoint exposed through Traefik.
# This is the host-facing published port. Traefik still listens on its internal
# livestream entrypoint port inside the container.
TRAEFIK_LIVESTREAM_BIND_IP=0.0.0.0
TRAEFIK_LIVESTREAM_PORT=3000

# Public OvenMediaEngine HTTP/TLS endpoint exposed through Traefik for
# Cloudflare-facing LL-HLS/WebRTC signaling traffic.
TRAEFIK_OME_BIND_IP=0.0.0.0
TRAEFIK_OME_PORT=2087

# Traefik dashboard stays localhost-only by default.
TRAEFIK_DASHBOARD_BIND_IP=127.0.0.1
TRAEFIK_DASHBOARD_PORT=8080

# ----------------------------------------------------------------------------- 
# Grafana Alloy published ports
# ----------------------------------------------------------------------------- 

# Alloy OTLP receivers stay internal-only; only the HTTP UI is published.
# The base production stack does not enable cAdvisor by default.
# Native Linux hosts can opt in with docker-compose.cadvisor.yml.
ALLOY_BIND_IP=127.0.0.1
ALLOY_HTTP_PORT=12345

# -----------------------------------------------------------------------------
# OvenMediaEngine published ports
# -----------------------------------------------------------------------------

# Standard OvenMediaEngine published ports.
# Set these to the real public OME hostname and allowed web origin in production.
OME_HOST_IP=your-public-ip-or-dns-name
OME_CORS_ALLOWED_ORIGIN=https://your-public-web-origin
OME_RTMP_BIND_IP=0.0.0.0
OME_RTMP_HOST_PORT=1935
OME_SRT_BIND_IP=0.0.0.0
OME_SRT_HOST_PORT=9999
OME_OVT_BIND_IP=0.0.0.0
OME_OVT_HOST_PORT=9000
# Keep OME's direct signaling port local-only in production and let Traefik
# own the public Cloudflare-facing port instead.
OME_SIGNAL_BIND_IP=127.0.0.1
OME_SIGNAL_HOST_PORT=3333
OME_TURN_BIND_IP=0.0.0.0
OME_TURN_HOST_PORT=3478
OME_ICE_BIND_IP=0.0.0.0
OME_ICE_HOST_START_PORT=10000
OME_ICE_HOST_END_PORT=10009
